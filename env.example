# ─────────────────────────────────────────
# VoiceIQ Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Microsoft Teams / Azure AD ───────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_BOT_ID=your-bot-app-id
AZURE_BOT_SECRET=your-bot-app-secret
TEAMS_PHONE_NUMBER=+44xxxxxxxxxx
CALLBACK_BASE_URL=https://voiceiq.co.uk

# ─── ElevenLabs ───────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_SOPHIA=your-voice-id
ELEVENLABS_VOICE_JAMES=your-voice-id
ELEVENLABS_VOICE_SHELLEY=your-voice-id
ELEVENLABS_VOICE_ALEXIS=your-voice-id

# ─── Google Gemini ────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─── Google Calendar ──────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/oauth/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_ID=primary

# ─── Security ─────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
API_KEY=change-this-to-a-secret-api-key-for-frontend

# ─── Rate Limiting ────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
